
@{
    ViewData["Title"] = "ViewTestimonial";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}
    @model GetTestimonialByIdDto


<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Testimonial Detay Sayfası</h4>
                    </div>
                    <div class="card-body">

                        <input type="hidden" asp-for="testimonialId" />

                        <div class="form-group">
                            <label>Ad Soyad</label>
                            <input type="text" asp-for="nameSurname"
                                   class="form-control" readonly />
                        </div>

                        <div class="form-group">
                            <label>Unvan</label>
                            <input type="text" asp-for="title"
                                   class="form-control" readonly />
                        </div>

                        <div class="form-group">
                            <label>Yorum</label>
                            <textarea asp-for="comment"
                                      class="form-control"
                                      rows="4"
                                      readonly></textarea>
                        </div>

                        <div class="form-group">
                            <label>Resim Url</label>
                            <input type="text" asp-for="imageUrl"
                                   class="form-control" readonly />
                        </div>

                        @if (!string.IsNullOrEmpty(Model.imageUrl))
                        {
                            <div class="form-group mt-3">
                                <label>Resim Önizleme</label><br />
                                <img src="@Model.imageUrl"
                                     style="max-width:200px; border-radius:8px;" />
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
