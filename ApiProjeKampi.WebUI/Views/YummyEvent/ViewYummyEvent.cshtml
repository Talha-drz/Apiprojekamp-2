
@{
    ViewData["Title"] = "ViewYummyEvent";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}
 @model GetYummyEventByIdDto

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Yummy Event Detay Sayfası</h4>
                    </div>
                    <div class="card-body">

                        <input type="hidden" asp-for="YummyEventId" />

                        <div class="form-group">
                            <label>Başlık</label>
                            <input type="text" asp-for="Title"
                                   class="form-control" readonly />
                        </div>

                        <div class="form-group">
                            <label>Açıklama</label>
                            <textarea asp-for="Description"
                                      class="form-control"
                                      rows="4"
                                      readonly></textarea>
                        </div>

                        <div class="form-group">
                            <label>Fiyat</label>
                            <input type="text"
                                   value="@Model.Price.ToString("C")"
                                   class="form-control" readonly />
                        </div>

                        <div class="form-group">
                            <label>Durum</label>
                            <input type="text"
                                   value="@(Model.Status ? "Aktif" : "Pasif")"
                                   class="form-control" readonly />
                        </div>

                        <div class="form-group">
                            <label>Resim Url</label>
                            <input type="text" asp-for="ImageUrl"
                                   class="form-control" readonly />
                        </div>

                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="form-group mt-3">
                                <label>Resim Önizleme</label><br />
                                <img src="@Model.ImageUrl"
                                     style="max-width:250px; border-radius:8px;" />
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

