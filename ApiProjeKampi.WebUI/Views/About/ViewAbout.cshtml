@model GetAboutByIdDto

@{
    ViewData["Title"] = "ViewAbout";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4>About Detay Sayfası</h4>
                    </div>
                    <div class="card-body">

                        <input type="hidden" asp-for="AboutId" />

                        <div class="form-group">
                            <label>Başlık</label>
                            <input type="text" asp-for="Title" class="form-control" readonly />
                        </div>

                        <div class="form-group">
                            <label>Açıklama</label>
                            <textarea asp-for="Description" class="form-control" rows="10" readonly></textarea>
                        </div>

                        <div class="form-group">
                            <label>Rezervasyon Numarası</label>
                            <input type="text" asp-for="ReservationNumber" class="form-control" readonly />
                        </div>

                        <div class="form-group">
                            <label>Video Url</label>
                            <input type="text" asp-for="VideoUrl" class="form-control" readonly />
                        </div>

                        <div class="form-group">
                            <label>Video Kapak Resmi Url</label>
                            <input type="text" asp-for="VideoCoverImageUrl" class="form-control" readonly />
                        </div>

                        <div class="form-group">
                            <label>Resim Url</label>
                            <input type="text" asp-for="ImageUrl" class="form-control" readonly />
                        </div>

                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="form-group mt-3">
                                <label>Resim Önizleme</label><br />
                                <img src="@Model.ImageUrl" style="max-width:300px; border-radius:8px;" />
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.VideoCoverImageUrl))
                        {
                            <div class="form-group mt-3">
                                <label>Video Kapak Önizleme</label><br />
                                <img src="@Model.VideoCoverImageUrl" style="max-width:300px; border-radius:8px;" />
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
