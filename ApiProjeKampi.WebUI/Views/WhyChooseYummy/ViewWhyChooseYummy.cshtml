
@{
    ViewData["Title"] = "ViewWhyChooseYummy";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@model GetWhyChooseYummyByIdDto

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Service Detay Sayfası</h4>
                    </div>
                    <div class="card-body">

                        <input type="hidden" asp-for="ServiceId" />

                        <div class="form-group">
                            <label>Başlık</label>
                            <input type="text" asp-for="Title" class="form-control" readonly />
                        </div>

                        <div class="form-group">
                            <label>Açıklama</label>
                            <textarea asp-for="Description" 
                                      class="form-control" 
                                      rows="4" 
                                      readonly></textarea>
                        </div>

                        <div class="form-group">
                            <label>Icon Url</label>
                            <input type="text" asp-for="IconUrl" class="form-control" readonly />
                        </div>

                        @if (!string.IsNullOrEmpty(Model.IconUrl))
                        {
                            <div class="form-group mt-3">
                                <label>Icon Önizleme</label><br />
                                <img src="@Model.IconUrl" 
                                     style="max-width:150px; border-radius:8px;" />
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
