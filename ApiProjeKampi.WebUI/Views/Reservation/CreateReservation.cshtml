@model CreateReservationDto

@{
    ViewData["Title"] = "CreateReservation";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Kategori Ekleme Sayfası</h4>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <label>isim soyisim</label>
                            <input type="text" asp-for="NameSurname" class="form-control" />
                            <br />
                            <label>Email</label>
                            <input type="email" asp-for="Email" class="form-control" />
                            <br />
                            <label>Telefon Numarası</label>
                            <input type="tel" asp-for="PhoneNumber" class="form-control" />
                            <br />
                            <label>Reservation Tarih</label>
                            <input type="date" asp-for="ReservationDate" class="form-control" />
                            <br />
                            <label>Reservation Saat</label>
                            <input type="datetime" asp-for="ReservationTime" class="form-control" />
                            <br />
                            <label>Kişi Sayısı</label>
                            <input type="number" asp-for="CountofPeople" class="form-control" />
                            <br />
                            <label>Messaj</label>
                            <input type="text" asp-for="Message" class="form-control" />
                            <br />
                            <label>Rezervasyon Durumu</label>
                            <input type="text" asp-for="ReservationStatus" class="form-control" />
                            <br />
                            <button class="btn btn-primary">Rezervason Oluştur</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

